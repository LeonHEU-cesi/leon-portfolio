# Caddyfile staging — reverse proxy + TLS auto Let's Encrypt.
# Monté dans le conteneur caddy (compose staging). Aucune valeur réelle ici :
# l'e-mail ACME est injecté via la variable d'environnement ACME_EMAIL.

{
  email {$ACME_EMAIL}
}

staging.leonheu.fr {
  encode zstd gzip
  reverse_proxy web:3000

  header {
    # Défense en profondeur (les headers applicatifs #6.1 restent la source).
    -Server
  }

  log {
    output stdout
  }
}
