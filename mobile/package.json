    "eslint": "^9.25.0",
    "eslint-config-expo": "~10.0.0",
    "jest": "^29.7.0",
    "jest-expo": "^55.0.17",
    "react-test-renderer": "^19.2.6",
    "typescript": "~5.9.2"
