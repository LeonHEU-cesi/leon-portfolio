# =====================================================
# leon-portfolio — exemple de configuration
# Copier ce fichier en .env et adapter les valeurs.
# Ne JAMAIS commiter .env (déjà ignoré par .gitignore).
# =====================================================

# --- Base de données ---
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/leonportfolio"

# --- Auth.js (NextAuth v5) ---
# Générer un secret avec: npx auth secret
AUTH_SECRET=""
AUTH_TRUST_HOST="true"

# --- GitHub API (pour le Hub repos publics) ---
# PAT lecture publique uniquement (scope: public_repo)
# https://github.com/settings/tokens
GITHUB_TOKEN=""
GITHUB_USERNAME="LeonHEU-cesi"

# --- Admin initial (utilisé par prisma seed) ---
ADMIN_EMAIL="leon@leonheu.fr"
ADMIN_PASSWORD="change_me_avant_prod"
ADMIN_NAME="Léon HEU"

# --- URL publique du site ---
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# --- Mobile (Expo) — utilisé dans mobile/.env, pas ici ---
# EXPO_PUBLIC_API_URL="http://192.168.x.y:3000"

# --- Logs ---
LOG_LEVEL="info"

# --- Rate limit (Upstash si externalisé en V2, sinon mémoire) ---
# UPSTASH_REDIS_REST_URL=""
# UPSTASH_REDIS_REST_TOKEN=""
